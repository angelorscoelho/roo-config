{
  "_doc": "Project-level MCP config. Commit this file. Zero credentials. Overrides global mcp_settings.json for listed servers.",
  "mcpServers": {
    "serena": {
      "command": "uvx",
      "args": [
        "--from", "git+https://github.com/oraios/serena",
        "serena", "start-mcp-server",
        "--context", "ide-assistant",
        "--project-from-cwd"
      ]
    },
    "Ref": {
      "_doc": "REPO: Ref.tools API integration.",
      "type": "streamable-http",
      "url": "https://api.ref.tools/mcp",
      "headers": {
        "X-ref-API-Key": "${env:REF_TOOLS_API_KEY}"
      }
    }
  }
}
